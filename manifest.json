{
  "manifest_version": 3,
  "name": "Input Checker",
  "description": "Check if current focused item is input field",
  "version": "1.0.0",

  "permissions": ["activeTab", "scripting"],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "browser_specific_settings": {
	  "gecko": {
		  "id": "input-checker@example.com"
	  }
  }
}
